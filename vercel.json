{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://13.48.134.87/stic/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "http://13.48.134.87/stic/storage/:path*"
    },
    {
      "source": "/((?!api/|storage/).*)",
      "destination": "/index.html"
    }
  ]
}
